CREATE PROCEDURE GetMonthlyRevenueReport
AS
BEGIN
    DECLARE @Target DECIMAL(12,2) = 500000;

    -- Step 1: Calculate monthly revenue and store in a temp table
    ;WITH MonthlyRevenue AS
    (
        SELECT 
            YEAR(a.AppointementDate) AS [Year],
            MONTH(a.AppointementDate) AS [Month],
            SUM(b.FinalAmount) AS TotalRevenue
        FROM Bill_tanvi b
        INNER JOIN Appointment_tanvi2 a
            ON b.AppointmentId = a.AppointmentId
        WHERE b.PaymentStatus = 'Paid'
        GROUP BY YEAR(a.AppointementDate), MONTH(a.AppointementDate)
    )
    SELECT *
    INTO #MonthlyRevenue
    FROM MonthlyRevenue;

    -- Step 2: Monthly report
    SELECT 
        DATENAME(MONTH, DATEFROMPARTS([Year],[Month],1)) + ' ' + CAST([Year] AS VARCHAR) AS MonthYear,
        TotalRevenue,
        CASE WHEN TotalRevenue >= @Target THEN 'Yes' ELSE 'No' END AS TargetMet,
        CASE 
            WHEN TotalRevenue >= @Target THEN TotalRevenue - @Target
            ELSE @Target - TotalRevenue
        END AS SurplusOrDeficit
    FROM #MonthlyRevenue
    ORDER BY [Year], [Month];

    -- Step 3: Final summary
    SELECT 
        SUM(CASE WHEN TotalRevenue >= @Target THEN 1 ELSE 0 END) AS MonthsMetTarget,
        SUM(CASE WHEN TotalRevenue < @Target THEN 1 ELSE 0 END) AS MonthsDidNotMeetTarget
    FROM #MonthlyRevenue;

    DROP TABLE #MonthlyRevenue;
END;

exec GetMonthlyRevenueReport;


