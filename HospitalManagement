--1 Prevent Doctor Double-Booking 

CREATE TRIGGER trg_PreventDoctorDoubleBooking
ON Appointment_tanvi2
AFTER INSERT
AS
BEGIN
    IF EXISTS (
        SELECT 1
        FROM Appointment_tanvi2 a
        JOIN inserted i
            ON a.DoctorId = i.DoctorId
           AND a.AppointementDate = i.AppointementDate
           AND a.TimeSlot = i.TimeSlot
        WHERE a.AppointmentId <> i.AppointmentId
          AND a.Status IN ('Scheduled','Completed')
    )
    BEGIN
        DECLARE @DoctorName VARCHAR(100),
                @Date DATE,
                @Time TIME,
                @DateStr VARCHAR(12),
                @TimeStr VARCHAR(8);

        SELECT 
            @DoctorName = d.DoctorName,
            @Date = i.AppointementDate,
            @Time = i.TimeSlot
        FROM inserted i
        JOIN Doctor_tanvi d 
            ON i.DoctorId = d.DoctorId;

        -- Convert values into strings before RAISERROR
        SET @DateStr = CONVERT(VARCHAR(12), @Date, 106);
        SET @TimeStr = CONVERT(VARCHAR(8), @Time, 108);

        RAISERROR(
            'Doctor %s already has an appointment scheduled at %s on %s.',
            16,
            1,
            @DoctorName,
            @TimeStr,
            @DateStr
        );

        ROLLBACK TRANSACTION;
    END
END;


--Auto-Generate Bill on Completion
CREATE TRIGGER trg_AutoGenerateBill
ON Appointment_tanvi2
AFTER UPDATE
AS
BEGIN
    -- Check if status changed to Completed
    IF EXISTS (
        SELECT 1
        FROM inserted i
        JOIN deleted d ON i.AppointmentId = d.AppointmentId
        WHERE i.Status = 'Completed'
          AND d.Status <> 'Completed'
    )
    BEGIN
        -- Prevent duplicate bills
        IF EXISTS (
            SELECT 1
            FROM Bill_tanvi b
            JOIN inserted i ON b.AppointmentId = i.AppointmentId
        )
        BEGIN
            RAISERROR('Bill already exists for this appointment.',16,1);
            ROLLBACK TRANSACTION;
            RETURN;
        END;

        -- Insert new bill
        INSERT INTO Bill_tanvi
        (
            AppointmentId,
            ConsultationAmount,
            MedicineAmount,
            LabAmount,
            InsuranceDiscount,
            GSTAmount,
            FinalAmount,
            PaymentStatus
        )
        SELECT  
            a.AppointmentId,
            d.ConsultationFee,
            ISNULL(SUM(m.Price * p.Quantity),0) AS MedicineCost,
            ISNULL(SUM(l.TestCost),0) AS LabCost,

            CASE
                WHEN ins.CoveragePercent IS NOT NULL
                THEN ((ISNULL(SUM(m.Price * p.Quantity),0)
                     + ISNULL(SUM(l.TestCost),0))
                     * ins.CoveragePercent/100)
                ELSE 0
            END AS InsuranceDiscount,

            (ISNULL(SUM(m.Price * p.Quantity),0) * 0.05
             + ISNULL(SUM(l.TestCost),0) * 0.12) AS GSTAmount,

            d.ConsultationFee
            + ISNULL(SUM(m.Price * p.Quantity),0)
            + ISNULL(SUM(l.TestCost),0)
            - CASE 
                WHEN ins.CoveragePercent IS NOT NULL
                THEN ((ISNULL(SUM(m.Price * p.Quantity),0)
                     + ISNULL(SUM(l.TestCost),0))
                     * ins.CoveragePercent/100)
                ELSE 0
              END
            + (ISNULL(SUM(m.Price * p.Quantity),0) * 0.05
               + ISNULL(SUM(l.TestCost),0) * 0.12) AS FinalAmount,

            'Unpaid'
        FROM inserted i
        JOIN Appointment_tanvi2 a ON i.AppointmentId = a.AppointmentId
        JOIN Doctor_tanvi d ON a.DoctorId = d.DoctorId
        LEFT JOIN MedicalRecord_tanvi mr ON a.AppointmentId = mr.AppointmentId
        LEFT JOIN Prescription_tanvi2 p ON mr.RecordId = p.RecordId
        LEFT JOIN Medicine m ON p.MedicineId = m.MedicineId
        LEFT JOIN OrderLabTest_tanvi olt ON mr.RecordId = olt.RecordId
        LEFT JOIN LabTest l ON olt.LabTestId = l.LabTestId
        LEFT JOIN Insurance2 ins ON a.PatientId = ins.PatientId
        WHERE i.Status = 'Completed'
        GROUP BY a.AppointmentId, d.ConsultationFee, ins.CoveragePercent;
    END
END;

