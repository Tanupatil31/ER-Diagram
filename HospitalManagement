     on mr.RecordId=i.RecordId
     where i.isAbnormal=1;

     if exists(
        select 1
        from inserted i
        left join MedicalRecord mr
           on i.RecordId=mr.RecordId
        where i.isAbnormal=1
        and mr.RecordId is null

     )

