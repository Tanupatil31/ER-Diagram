create procedure GetDoctorPerformanceSummary
   @MinAppointments int
as
begin
  ;with DoctorStats as
  (
     select d.DoctorId,d.DoctorName,
     count (a.AppointmentId) as TotalAppointments,
     sum(
       case when a.Status='Completed' then 1
       else 0
       end
     )as TotalCompletedAppointmtnts,

     isnull(sum(
     case when a.Status='Completed'
     then b.FinalAmount
     else 0
     end
     ),0) as TotalRevenue,

     count(distinct
     case when a.Status='Completed'
     then mr.Diagnosis
     else null
     end
  )as UniqueDiagnoses
  from Doctor_tanvi d
  left join Appointment_tanvi2 a on d.DoctorId=a.DoctorId
  left join Bill_tanvi b on a.AppointmentId=b.AppointmentId
  left join MedicalRecord_tanvi mr on a.AppointmentId=mr.AppointmentId
  where d.isActive = 1
  group by d.DoctorId, d.DoctorName
  )

  select DoctorId,DoctorName,TotalAppointments,TotalCompletedAppointmtnts,
  case when TotalAppointments =0 then 0
  else cast(
  (TotalCompletedAppointmtnts*100.0)/TotalAppointments as decimal(5,2)
  )
  end as CompletionRatePercentage,
  TotalRevenue,
  UniqueDiagnoses
  from DoctorStats
  where TotalAppointments>=@MinAppointments
  order by TotalRevenue desc;
end;

