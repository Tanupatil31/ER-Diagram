CREATE PROCEDURE GetPatientBillingHistory
   @PatientId INT
AS
BEGIN
  IF NOT EXISTS (SELECT 1 FROM Patient_tanvi WHERE PatientId = @PatientId)
  BEGIN
    RAISERROR('Patient Id does not exist.',16,1);
    RETURN;
  END;

  ;WITH BillingData AS
  (
    SELECT 
      a.AppointementDate,
      d.DoctorName,
      b.ConsultationAmount AS ConsultationCharge,
      b.MedicineAmount AS TotalMedicineCost,
      b.LabAmount AS TotalLabCost,
      b.InsuranceDiscount,
      b.GSTAmount,
      b.FinalAmount
    FROM Appointment_tanvi2 a
    INNER JOIN Doctor_tanvi d ON a.DoctorId = d.DoctorId
    INNER JOIN Bill_tanvi b ON a.AppointmentId = b.AppointmentId
    WHERE a.PatientId = @PatientId
      AND a.Status = 'Completed'
  )
  SELECT 
    CONVERT(VARCHAR(12), AppointementDate, 106) AS AppointementDate,
    DoctorName,
    ConsultationCharge,
    TotalMedicineCost,
    TotalLabCost,
    InsuranceDiscount,
    GSTAmount,
    FinalAmount,
    0 AS SortOrder
  FROM BillingData

  UNION ALL

  SELECT 
    'Grand Total' AS AppointementDate,
    NULL AS DoctorName,
    SUM(ConsultationCharge),
    SUM(TotalMedicineCost),
    SUM(TotalLabCost),
    SUM(InsuranceDiscount),
    SUM(GSTAmount),
    SUM(FinalAmount),
    1 AS SortOrder
  FROM BillingData

  ORDER BY SortOrder, AppointementDate;
END;

