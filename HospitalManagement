create procedure GetMonthlyDepartment2
   @month int,
   @year int
as
begin
set nocount on;

select d.DepartmentId, d.DepartmentName,
count (a.AppointmentId) as TotalAppointment,
count (distinct a.PatientId) as UniquePatients,
isnull(sum(
     case 
       when a.Status='Completed'
       then doc.ConsultationFee
       else 0
    end
    ),0) as TotalConsultationRevenue
from Department_tanvi d
left join Doctor_tanvi doc
on d.DepartmentId=doc.DepartmentId
left join Appointment_tanvi2 a
  on doc.DoctorId=a.DoctorId
  and month(a.AppointementDate)=@month
  and year(a.AppointementDate)=@year

group by d.DepartmentId, d.DepartmentName
order by d.DepartmentName;

end

