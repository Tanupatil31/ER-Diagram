--D1 Top 3 Doctors per Department by Revenue 

with DoctorRevenue as
(
    select 
       d.DepartmentName,
       doc.DoctorName,
       doc.DoctorId,
       sum(b.FinalAmount) as TotalRevenue
    from Doctor_tanvi doc
    join Department_tanvi d
       on doc.DepartmentId=d.DepartmentId
    join Appointment_tanvi2 a
       on doc.DoctorId=a.DoctorId
    join Bill_tanvi b
       on a.AppointmentId=b.AppointmentId
    where a.Status='Completed'
    group by d.DepartmentName,doc.DoctorName,doc.DoctorId
),

RankedDoctors as
(
  select *,
    RANK() OVER(
         PARTITION by DepartmentName
         order by TotalRevenue desc

    )as DepartmentRank
    from DoctorRevenue
)

select 
   DepartmentName,
   DoctorName,
   TotalRevenue,
   DepartmentRank
   from RankedDoctors
   where DepartmentRank<=3
   order by DepartmentName,DepartmentRank;

